{
  "name": "onsite-backend",
  "version": "0.0.0",
  "description": "REST API для Onsite — mini-CRM выездных сервисных работников",
  "private": true,
  "type": "module",
  "license": "PolyForm-Noncommercial-1.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "openapi:print": "tsx scripts/openapi-print.ts",
    "openapi:validate": "tsx scripts/openapi-validate.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "typebox": "^1.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@seriousme/openapi-schema-validator": "^2.9.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "semantic-release": "^25.0.5",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
