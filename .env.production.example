# Продакшн self-host стек (compose.production.yml). Скопировать в .env.production и заполнить
# реальными значениями — .env.production не коммитить (см. .gitignore).
#
# Запуск: docker compose -f compose.production.yml --env-file .env.production up -d

# Версия образа GHCR (api/migrate): пин конкретного релиза для воспроизводимых деплоев,
# latest — дефолт для первого запуска. Список версий — Releases репозитория на GitHub.
APP_VERSION=latest

# Домены (DNS A-записи должны указывать на сервер до старта — Caddy сам выпускает TLS-сертификаты).
DOMAIN_API=api.example.com
DOMAIN_STORAGE=storage.example.com
# Контактный email для Let's Encrypt (уведомления об истечении сертификата и т.п.).
ACME_EMAIL=admin@example.com

# PostgreSQL — без дефолтов вида `onsite`/`onsite`: задать собственные значения.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=onsite

# MinIO — без дефолтов вида `minioadmin`/`minioadmin`: задать собственные значения.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_BUCKET=onsite-photos

# JWT RS256: base64-кодированные PEM-ключи. Сгенерировать: npx tsx scripts/generate-jwt-keys.ts.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000
REFRESH_CLEANUP_INTERVAL_MIN=60
REFRESH_EXPIRED_GRACE_DAYS=7

# Уровень логирования pino: trace | debug | info | warn | error | fatal.
LOG_LEVEL=info

# Expo Push (T-16): access-токен enhanced security — опционален.
EXPO_ACCESS_TOKEN=
PUSH_WORKER_INTERVAL_SEC=10
PUSH_RECEIPT_DELAY_MIN=15
PUSH_MAX_ATTEMPTS=5

# Rate limiting (T-17): глобальный лимит на IP + жёсткий на /v1/auth/*.
RATE_LIMIT_GLOBAL_MAX=200
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000

# Бэкапы (NFR-03): сколько дней хранить снапшоты pg_dump/MinIO в volume `backups`.
BACKUP_RETENTION_DAYS=14
