# Окружение приложения: development | production | test.
NODE_ENV=development

# HTTP-сервер.
HOST=0.0.0.0
PORT=3000

# Уровень логирования pino: trace | debug | info | warn | error | fatal.
LOG_LEVEL=debug

# PostgreSQL.
DATABASE_URL=postgres://onsite:onsite@localhost:5432/onsite

# MinIO / S3 (используется с Фазы 4, объявлено заранее для docker compose).
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=onsite-photos
