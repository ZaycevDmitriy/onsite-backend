# Окружение приложения: development | production | test.
NODE_ENV=development

# HTTP-сервер.
HOST=0.0.0.0
PORT=3000

# Уровень логирования pino: trace | debug | info | warn | error | fatal.
LOG_LEVEL=debug

# PostgreSQL.
DATABASE_URL=postgres://onsite:onsite@localhost:5432/onsite

# JWT RS256: base64-кодированные PEM-ключи. Сгенерировать: npx tsx scripts/generate-jwt-keys.ts.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# TTL токенов в секундах: access — 15 минут, refresh — 30 дней.
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# Зачистка просроченных refresh-сессий: интервал прогона (мин), grace-период после expiresAt (дни).
REFRESH_CLEANUP_INTERVAL_MIN=60
REFRESH_EXPIRED_GRACE_DAYS=7

# MinIO / S3: хранилище фотоотчётов.
S3_ENDPOINT=http://localhost:9000
# Публичный эндпоинт для presigned URL, доступного клиенту; по умолчанию — S3_ENDPOINT.
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=onsite-photos

# Фото: лимит размера (МБ), TTL presigned URL (сек), TTL staged-сирот (часы), интервал зачистки (мин).
PHOTO_MAX_SIZE_MB=10
PHOTO_PRESIGN_TTL_SEC=600
PHOTO_STAGED_TTL_HOURS=168
PHOTO_CLEANUP_INTERVAL_MIN=60

# Синк: safety-lag курсора pull в единицах sync_seq.
SYNC_SAFETY_LAG=100

# Expo Push (T-16): access-токен enhanced security — опционален.
EXPO_ACCESS_TOKEN=
# Push-worker: интервал прогона (сек), задержка перед проверкой receipt'ов (мин), лимит попыток.
PUSH_WORKER_INTERVAL_SEC=10
PUSH_RECEIPT_DELAY_MIN=15
PUSH_MAX_ATTEMPTS=5

# Rate limiting (T-17): глобальный лимит на IP + жёсткий на /v1/auth/*.
RATE_LIMIT_GLOBAL_MAX=200
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000
